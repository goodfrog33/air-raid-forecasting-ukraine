# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# Jupyter
.ipynb_checkpoints/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# OS
.DS_Store

# Data — raw downloads and processed artifacts are reproducible from the pipeline.
# Tracked: small metadata + .gitkeep. Ignored: bulk CSV/parquet.
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep
!data/external/ukraine_oblasts.geojson
data/processed/*
!data/processed/.gitkeep
# Compact artifacts the deployed dashboard reads (committed so Streamlit Cloud
# can serve without re-running the pipeline). Bulk feature matrices stay ignored.
!data/processed/alerts_events_labeled.parquet
!data/processed/panel_national_hourly.parquet
!data/processed/panel_region_hourly.parquet
!data/processed/forecast_national.parquet

# Trained model artifacts (regenerated by the training pipeline). The deployable
# bundle is committed so Streamlit Cloud can serve it without retraining.
models/*
!models/.gitkeep
!models/model_bundle.joblib

# Generated figures ARE committed (small PNGs; they showcase results and are
# referenced by the notebooks). Regenerate any time with the EDA/train steps.

# Logs & secrets
logs/
*.log
.env
