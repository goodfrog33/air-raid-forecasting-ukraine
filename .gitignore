# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# Jupyter
.ipynb_checkpoints/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# OS
.DS_Store

# Data — raw downloads and processed artifacts are reproducible from the pipeline.
# Tracked: small metadata + .gitkeep. Ignored: bulk CSV/parquet.
data/raw/*
!data/raw/.gitkeep
data/external/*
!data/external/.gitkeep
!data/external/ukraine_oblasts.geojson
data/processed/*
!data/processed/.gitkeep

# Trained model artifacts (regenerated by the training pipeline)
models/*
!models/.gitkeep

# Generated figures ARE committed (small PNGs; they showcase results and are
# referenced by the notebooks). Regenerate any time with the EDA/train steps.

# Logs & secrets
logs/
*.log
.env
