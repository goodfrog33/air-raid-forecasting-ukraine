# Copy to .env and adjust as needed. All variables are optional; sensible
# defaults live in configs/config.yaml.

# Override the config file used by the whole pipeline.
ARF_CONFIG=configs/config.yaml

# Logging level: DEBUG | INFO | WARNING | ERROR
ARF_LOG_LEVEL=INFO

# Path the prediction service / dashboard read the trained model bundle from.
ARF_MODEL_DIR=models

# Optional external-data API keys (only needed if you enable those connectors).
# OpenWeather / Meteostat for weather enrichment (Phase 4, optional):
WEATHER_API_KEY=
# GDELT requires no key. News API key (optional):
NEWS_API_KEY=
